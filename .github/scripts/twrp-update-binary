#!/sbin/sh
# TWRP update-binary for postmarketOS kernel (Samsung Exynos 850)
# Flashes raw kernel Image to BOOT partition

OUTFD=/proc/self/fd/$2
TMP=/tmp/boot-install

ui_print() {
  echo "ui_print $1" > "$OUTFD"
  echo "ui_print" > "$OUTFD"
}

set_progress() {
  echo "set_progress $1" > "$OUTFD"
}

set -e

ui_print "============================================"
ui_print "  postmarketOS kernel for Samsung A12s"
ui_print "  (SM-A127F, Exynos 850)"
ui_print "============================================"
ui_print ""

set_progress 0.1

mkdir -p "$TMP"
cd "$TMP"

ui_print "- Extracting kernel Image..."
unzip -o "$3" Image -d "$TMP"

set_progress 0.4

if [ ! -f Image ]; then
  ui_print "! ERROR: Image not found in zip"
  exit 1
fi

ui_print "- Detecting boot partition..."

BOOT_DEV=""
for dev in /dev/block/bootdevice/by-name/boot \
           /dev/block/platform/*/by-name/boot \
           /dev/block/by-name/boot; do
  if [ -b "$dev" ]; then
    BOOT_DEV="$dev"
    break
  fi
done

if [ -z "$BOOT_DEV" ]; then
  ui_print "! ERROR: Could not find boot partition"
  ui_print "! Available block devices:"
  ls -la /dev/block/bootdevice/ 2>/dev/null
  ls -la /dev/block/by-name/ 2>/dev/null
  exit 1
fi

ui_print "- Partition: $BOOT_DEV"
set_progress 0.6

# Backup original
ui_print "- Backing up original boot..."
dd if="$BOOT_DEV" of="$SDCARD/boot-backup.img" bs=4096 2>/dev/null || true
set_progress 0.7

ui_print "- Flashing kernel Image (raw)..."
dd if=Image of="$BOOT_DEV" bs=4096
set_progress 0.9

ui_print "- Cleaning up..."
rm -rf "$TMP"

set_progress 1.0

ui_print ""
ui_print "============================================"
ui_print "  Done! Kernel flashed."
ui_print "  Backup saved to /sdcard/boot-backup.img"
ui_print "  Reboot to apply."
ui_print "============================================"
