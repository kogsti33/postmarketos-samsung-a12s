#!/sbin/sh
# TWRP update-binary for postmarketOS kernel zip

OUTFD=/proc/self/fd/$2
TMP=/tmp/boot-install

ui_print() {
  echo "ui_print $1" > "$OUTFD"
  echo "ui_print" > "$OUTFD"
}

set_progress() {
  echo "set_progress $1" > "$OUTFD"
}

is_slot_device() {
  grep -q "boot.slot_suffix" /proc/cmdline 2>/dev/null
}

set -e

ui_print "============================================"
ui_print "  postmarketOS kernel for Samsung A12s"
ui_print "  (SM-A127F, Exynos 850)"
ui_print "============================================"
ui_print ""

set_progress 0.1

mkdir -p "$TMP"
cd "$TMP"

ui_print "- Extracting boot.img..."
unzip -o "$3" boot.img -d "$TMP"

set_progress 0.4

if [ ! -f boot.img ]; then
  ui_print "! ERROR: boot.img not found in zip"
  exit 1
fi

ui_print "- Detecting boot partition..."

BOOT_DEV=""
for dev in /dev/block/bootdevice/by-name/boot \
           /dev/block/platform/*/by-name/boot \
           /dev/block/by-name/boot; do
  if [ -b "$dev" ]; then
    BOOT_DEV="$dev"
    break
  fi
done

if [ -z "$BOOT_DEV" ]; then
  ui_print "! ERROR: Could not find boot partition"
  exit 1
fi

ui_print "- Partition: $BOOT_DEV"
set_progress 0.6

# Backup original boot
ui_print "- Backing up original boot..."
dd if="$BOOT_DEV" of="$TMP/boot-backup.img" bs=4096 2>/dev/null
set_progress 0.7

ui_print "- Flashing boot.img..."
dd if=boot.img of="$BOOT_DEV" bs=4096
set_progress 0.9

ui_print "- Cleaning up..."
rm -rf "$TMP"

set_progress 1.0

ui_print ""
ui_print "============================================"
ui_print "  Done! Reboot to apply."
ui_print "============================================"
